# .env.local.example
# Copy this to .env.local and fill in your values

# ============================================================
# DATABASE (Required)
# ============================================================
# Get a free PostgreSQL database at:
# - https://supabase.com (free tier, 500MB)
# - https://neon.tech (free tier, 512MB)
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL="postgresql://neondb_owner:npg_d8DWvXqEcY7e@ep-bitter-dawn-an7oqzgv-pooler.c-6.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# ============================================================
# GOOGLE MAPS API (Optional but recommended)
# ============================================================
# Without this key, the app uses realistic mock data.
# Get a key at: https://console.cloud.google.com
# Enable: Places API, Maps JavaScript API
# Estimated cost: ~$17 per 1000 searches (free $200/month credit)
GOOGLE_MAPS_API_KEY=""

# ============================================================
# APP CONFIG (Optional)
# ============================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
